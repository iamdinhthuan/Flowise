# Docker Compose Environment Variables
# Copy this to .env and fill in the values before running docker-compose up

# ── Database ──
POSTGRES_USER=flowise
POSTGRES_PASSWORD=39edbdedd6a5142f4c6a1907d5dd6cf6991903c8c368bd643acc43466af941d4
POSTGRES_DB=flowise
POSTGRES_PORT_BIND=127.0.0.1
POSTGRES_PORT=5432

# ── Redis ──
REDIS_URL=redis://redis:6379
REDIS_KEEP_ALIVE=30000

# ── Flowise ──
FLOWISE_PORT=3000
# Keep MODE=main for the single Flowise container. MODE=queue also needs a worker process.
MODE=main
FLOWISE_DEFAULT_BODY_SIZE_LIMIT=5mb
FLOWISE_FILE_SIZE_LIMIT=50mb
FLOWISE_OPEN_SOURCE_AUTH_ENABLED=true
SECURE_COOKIES=false
TRUST_PROXY=false
CHATFLOW_CACHE_TTL_MS=5000
CHATFLOW_CACHE_MAX_ENTRIES=1000
CHAT_MESSAGE_DEFAULT_PAGE_SIZE=100
CHAT_MESSAGE_MAX_PAGE_SIZE=500
WORKER_CONCURRENCY=5
QUEUE_MAX_WAITING_JOBS=1000
REMOVE_ON_AGE=86400
REMOVE_ON_COUNT=1000
# Enables Redis-backed LLM, embeddings, and SSO handoff caches without forcing queue mode.
CACHE_POOL_REDIS_ENABLED=true
CACHE_POOL_MAX_ENTRIES=500
CACHE_POOL_TTL_SECONDS=86400
FLOWISE_MAX_INDEXING_DOCUMENTS=10000
FLOWISE_MAX_INDEXING_CHARACTERS=20000000
